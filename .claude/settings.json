{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-env.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(which *)",
      "Bash(python3 --version)",
      "Bash(python3 -c *)",
      "Bash(pip3 install:*)",
      "Bash(pip install:*)",
      "Bash(uname -s)",
      "Bash(brew --version)",
      "Bash(brew install:*)",
      "Bash(tmux -V)",
      "Bash(find ~ -maxdepth 4 -name .env*)",
      "Bash(cat .env*)",
      "Bash(cp .env*)",
      "Bash(mkdir -p *)",
      "Bash(bash scripts/*)"
    ]
  }
}
