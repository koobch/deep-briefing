    {
      "text": "How does the role of the IT function change in an AI-first organization?",
      "x": 384.8,
      "y": 298.7,
      "w": 483.2,
      "h": 17.9,
      "font": "HendersonBCGSans-Light",
      "size": 16.0,
      "color": "#000000",
      "flags": 0
    },
    {
      "text": "What happens when tech investment surpasses all other cost centers ",
      "x": 384.8,
      "y": 211.8,
      "w": 479.5,
      "h": 17.9,
      "font": "HendersonBCGSans-Light",
      "size": 16.0,
      "color": "#000000",
      "flags": 0
    },
    {
      "text": "in the P&L?",
      "x": 384.8,
