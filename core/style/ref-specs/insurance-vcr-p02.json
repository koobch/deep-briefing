      "h": 23.4,
      "font": "HendersonBCGSans-Regular",
      "size": 18.0,
      "color": "#464547",
      "flags": 0
    },
    {
      "text": "insurance TSR over the past five years. Growth has proven ",
      "x": 692.1,
      "y": 504.1,
      "w": 457.5,
      "h": 23.4,
      "font": "HendersonBCGSans-Regular",
      "size": 18.0,
      "color": "#464547",
      "flags": 0
    },
    {
