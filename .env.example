# ============================================================
# Deep-Briefing — API 키 설정
# ============================================================
# 이 파일을 복사하여 .env로 만든 뒤, 실제 키를 입력하세요.
#   cp .env.example .env
#   또는: ./scripts/setup-api-keys.sh (대화형 설정)
#
# 주의: .env 파일은 .gitignore에 포함되어 있어 git에 커밋되지 않습니다.
# ============================================================

# ------------------------------------------------------------
# [필수] 리서치 품질에 직접 영향
# ------------------------------------------------------------

# DART Open API — 한국 기업 공시 (무료, 즉시 발급)
# 발급: https://opendart.fss.or.kr (회원가입 → 인증키 신청)
# 용도: 한국 게임사 재무제표, 공시 검색, 직원 현황 등
# 일일 한도: 10,000건
DART_API_KEY=your_dart_api_key_here

# Exa.ai — 고품질 웹 검색 (유료)
# 발급: https://exa.ai (가입 후 API Key 발급)
# 용도: 산업 리포트, 뉴스, 전문 자료 검색
EXA_API_KEY=your_exa_api_key_here

# ------------------------------------------------------------
# [권장] 특정 Division 분석 보강
# ------------------------------------------------------------

# Steam Web API — 게임 동시접속자, 리뷰 데이터 (무료)
# 발급: https://steamcommunity.com/dev/apikey (Steam 계정 필요)
# 용도: Product Division — PC 게임 시장 데이터
STEAM_API_KEY=your_steam_api_key_here

# FRED API — 미국 매크로 경제지표 (무료)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
# 용도: Finance Division — GDP, CPI, 환율, 실업률 등
FRED_API_KEY=your_fred_api_key_here

# 한국은행 ECOS API — 한국 매크로 경제지표 (무료)
# 발급: https://ecos.bok.or.kr/api/ (회원가입 → 인증키 신청)
# 용도: Finance Division — 한국 GDP, 물가, 환율 등
# 일일 한도: 500건 (무료)
ECOS_API_KEY=your_ecos_api_key_here

# NewsAPI — 글로벌 뉴스 검색 (무료 tier: 100건/일)
# 발급: https://newsapi.org (가입 후 즉시 발급)
# 용도: Market Division — 산업 뉴스 모니터링
# 제한: 무료 tier는 과거 1개월만 검색 가능
NEWSAPI_KEY=your_newsapi_key_here

# ------------------------------------------------------------
# [선택] 키 불요 또는 대체 가능
# ------------------------------------------------------------

# SEC EDGAR — 키 불필요 (User-Agent만 설정)
# 아래 값을 본인 정보로 변경하세요
SEC_EDGAR_USER_AGENT="ResearchOrchestrator research@example.com"

# Yahoo Finance — 키 불필요 (비공식 API)
# Google Trends — pytrends 라이브러리 (키 불필요)
# IGDB — Twitch Developer 인증 필요 (복잡, 대체 가능 — 필요 시 별도 설정)
