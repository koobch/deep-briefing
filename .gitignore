.env
data/user-provided/

# 대용량 사용자 데이터 (Git 크기 제한 초과)
*/data/user-provided/*.csv

# === 도메인 특화 콘텐츠 (오픈소스 배포 시 제외) ===
# 오픈소스 사용자는 domains/example/를 복사하여 자신의 도메인을 생성
domains/game-strategy/

# === 빌드/캐시 산출물 ===
node_modules/
__pycache__/
*.pyc
*/reports/charts/
*/reports/chart-index.yaml

# === Phase 4.7 HTML/PDF 파생물 (MD 정본 유지, HTML/PDF는 재생성 가능) ===
*/reports/*.html
*/reports/*.pdf
*/.html-manifest.txt
*/reports/.html-manifest.txt
*/qa/audit-log.md

# === 프로젝트별 실행 결과 (리서치 산출물 — 민감 데이터 포함 가능) ===
# 프로젝트 디렉토리는 리서치 실행 시 자동 생성되며, 공개 저장소에 포함하지 않는다.
neo-new-title-strategy/
neo-ai-transformation/
economy-shorts-channel/
